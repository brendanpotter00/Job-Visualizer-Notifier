{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build -w src/frontend",
  "installCommand": "npm install",
  "outputDirectory": "src/frontend/dist",
  "rewrites": [
    {
      "source": "/api/greenhouse/:path(.*)",
      "destination": "/api/greenhouse?path=:path"
    },
    {
      "source": "/api/lever/:path(.*)",
      "destination": "/api/lever?path=:path"
    },
    {
      "source": "/api/ashby/:path(.*)",
      "destination": "/api/ashby?path=:path"
    },
    {
      "source": "/api/workday/:path(.*)",
      "destination": "/api/workday?path=:path"
    },
    {
      "source": "/api/gem/:path(.*)",
      "destination": "/api/gem?path=:path"
    },
    {
      "source": "/api/eightfold/:path(.*)",
      "destination": "/api/eightfold?path=:path"
    },
    {
      "source": "/api/jobs-qa",
      "destination": "/api/jobs-qa"
    },
    {
      "source": "/api/jobs-qa/:path(.*)",
      "destination": "/api/jobs-qa?path=:path"
    },
    {
      "source": "/api/users",
      "destination": "/api/users"
    },
    {
      "source": "/api/users/:path(.*)",
      "destination": "/api/users?path=:path"
    },
    {
      "source": "/api/features",
      "destination": "/api/features"
    },
    {
      "source": "/api/features/:path(.*)",
      "destination": "/api/features?path=:path"
    },
    {
      "source": "/recent-jobs",
      "destination": "/index.html"
    },
    {
      "source": "/qa",
      "destination": "/index.html"
    },
    {
      "source": "/why",
      "destination": "/index.html"
    },
    {
      "source": "/companies",
      "destination": "/index.html"
    },
    {
      "source": "/account",
      "destination": "/index.html"
    },
    {
      "source": "/vote-features",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://job-visualizer-notifier.vercel.app"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, X-Workday-Base-Url, X-Eightfold-Tenant-Host, Authorization"
        }
      ]
    }
  ]
}
